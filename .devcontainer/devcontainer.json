{
  "name": "qfolio-arena",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "JuanBlanco.solidity",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "postCreateCommand": "pip install -e core/[dev] && pip install fastapi uvicorn gradio huggingface_hub",
  "forwardPorts": [5173, 8000],
  "portsAttributes": {
    "5173": { "label": "Frontend (Vite)" },
    "8000": { "label": "Solver API (FastAPI)" }
  }
}